# Authentication and database
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
DATABASE_URL=

# Cloudflare R2 image uploads (optional; text-only posts work without these).
# Keep this bucket private. Images are served through an authorized app route.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# Comma-separated exact browser origins allowed to request upload URLs.
R2_ALLOWED_ORIGINS=http://localhost:3000
